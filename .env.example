# Azure OpenAI configuration for the GPT-4o mini deployment.
# Copy this file to .env and fill in your values.

AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-10-21
# This is the *deployment name* you gave your gpt-4.1-mini model in Azure,
# which may differ from the base model name.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# --- LLM provider ----------------------------------------------------------
# "azure" (default) uses the Azure OpenAI settings above.
# "ollama" uses a local Ollama server via its OpenAI-compatible API.
# Restart the app after changing (provider is read once at startup).
LLM_PROVIDER=azure
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5

# --- Leave automation (sumHR) ----------------------------------------------
# sumHR login credentials are NOT stored here. They live in the Windows
# Credential Manager (service "Qubi-sumHR"), prompted for once on first use.
#
# Optional (packaged builds only): location of the bundled Playwright browser.
# Set automatically by the app via app_base_dir(); leave unset in development.
# PLAYWRIGHT_BROWSERS_PATH=
