# Azure OpenAI configuration for the GPT-4o mini deployment.
# Copy this file to .env and fill in your values.

AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-10-21
# This is the *deployment name* you gave your gpt-4.1-mini model in Azure,
# which may differ from the base model name.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# --- LLM provider ----------------------------------------------------------
# "azure" (default) uses the Azure OpenAI settings above.
# "ollama" uses a local Ollama server via its OpenAI-compatible API.
# Restart the app after changing (provider is read once at startup).
LLM_PROVIDER=azure
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5

# --- MCP servers (Entra-authenticated tool calling) ------------------------
# The chatbot signs the user into Entra ID (MSAL interactive browser) and calls
# each system's read-only MCP server with the resulting per-user access token.
# Each internal system is one MCP server with its own URL + Entra scope; adding a
# system is config only (a <SYS>_MCP_URL and an ENTRA_SCOPE_<SYS> here, plus an
# entry in identity.py / mcp_client.py / routing.py). Leave a system's URL unset
# to disable its tools — HR policy Q&A still works regardless.
#
# Entra base (tenant + client app registration), shared across systems:
ENTRA_TENANT_ID=cea95265-0690-4a6d-9251-e12e48630c60
ENTRA_CLIENT_ID=fad88ee9-4a38-43c9-9a66-cece733f6d3e
#
# Finance (the system wired up today):
FINANCE_MCP_URL=http://localhost:5301
# Per-system scope: must match the scope exposed under "Expose an API" on the
# target system's app reg. The legacy ENTRA_SCOPE below is still honoured for
# finance for backward compatibility; prefer ENTRA_SCOPE_FINANCE going forward.
ENTRA_SCOPE_FINANCE=api://fad88ee9-4a38-43c9-9a66-cece733f6d3e/access_user
ENTRA_SCOPE=api://fad88ee9-4a38-43c9-9a66-cece733f6d3e/access_user
#
# Future systems (uncomment + fill, and enable in the code registries):
# HR_MCP_URL=http://localhost:5302
# ENTRA_SCOPE_HR=api://<hr-app-id>/access_user
# PROJECT_MCP_URL=http://localhost:5303
# ENTRA_SCOPE_PROJECT=api://<project-app-id>/access_user
# CRM_MCP_URL=http://localhost:5304
# ENTRA_SCOPE_CRM=api://<crm-app-id>/access_user
#
# NOTE (secrets / hardening): the per-user token above is delegated — there is no
# standing/broad service-account credential, and that must stay true. The Azure
# OpenAI key in this file is a demo convenience only; for production move the
# *gateway's own* credential to a federated identity credential / managed
# identity and keep secrets out of the shipped bundle.

# --- Leave automation (sumHR) ----------------------------------------------
# sumHR login credentials are NOT stored here. They live in the Windows
# Credential Manager (service "Qubi-sumHR"), prompted for once on first use.
#
# Optional (packaged builds only): location of the bundled Playwright browser.
# Set automatically by the app via app_base_dir(); leave unset in development.
# PLAYWRIGHT_BROWSERS_PATH=
